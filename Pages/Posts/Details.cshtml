@page
@model BlogSite.Pages_Posts.DetailsModel

@{
    ViewData["Title"] = Model.Post.Title;
}

<h1>@Model.Post.Title</h1>

<div class="row">
    <div class="col-md-8">
        <p>@Model.Post.Content</p>
    </div>

    <div class="col-md-4">
        <h2>Related posts</h2>
        @foreach(var posts in Model.Posts) {
            <ul>
                <li><a asp-page="/Posts/Details" asp-route-id="@posts.Id">@posts.Title</a></li>
            </ul>
        }
    </div>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Post.Id">Edit</a> |
    <a asp-page="/Index">Back to List</a>
</div>
